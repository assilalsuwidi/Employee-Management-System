# انسخ هذا الملف إلى .env ولا ترفع .env أبداً إلى GitHub (موجود أصلاً في .gitignore)
FLASK_CONFIG=development

# أنشئ قيمًا عشوائية طويلة، مثلاً عبر: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-a-different-long-random-string

DATABASE_URL=mysql+pymysql://root:root_password@db/ems_db
TEST_DATABASE_URL=sqlite:///:memory:

JWT_ACCESS_TOKEN_EXPIRES_MIN=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

CORS_ORIGINS=http://localhost:5173

# بريد التنبيهات (لا تضع القيم الحقيقية هنا، فقط في .env المحلي غير المرفوع)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

DB_ROOT_PASSWORD=root_password
