# انسخ هذا الملف إلى .env ولا ترفع .env أبداً إلى GitHub (موجود أصلاً في .gitignore)
FLASK_CONFIG=development

# أنشئ قيمًا عشوائية طويلة، مثلاً عبر: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-a-different-long-random-string

DATABASE_URL=mysql+pymysql://root:your_db_password_here@db/ems_db
TEST_DATABASE_URL=sqlite:///:memory:

JWT_ACCESS_TOKEN_EXPIRES_MIN=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# refresh token يُرسَل الآن في كوكي httpOnly (وليس في جسم استجابة
# JSON). اتركها true دائمًا خلف HTTPS. اضبطها false محليًا فقط إن كنت
# تشغّل الواجهة الأمامية بدون TLS (مثال: http://localhost:5173 بدون
# شهادة)، وإلا فلن يقبل المتصفح تخزين الكوكي.
JWT_COOKIE_SECURE=true

# الإصلاح: Talisman كان يُجبَر دائمًا على force_https=False بصرف النظر
# عن بيئة التشغيل. اتركها true خلف HTTPS (القيمة الافتراضية في
# الإنتاج أصلاً true حتى بدون تعريف هذا المتغير). اضبطها false محليًا
# فقط إن كنت تُشغّل الباك إند مباشرة بدون TLS.
FORCE_HTTPS=true

CORS_ORIGINS=http://localhost:5173

# إعداد المستخدم المسؤول الأولي (يُستخدم مرة واحدة عند أول تشغيل)
# يجب تعيين هذه المتغيرات عند تشغيل النظام لأول مرة لإنشاء مستخدم مسؤول آمن.
# INITIAL_ADMIN_USER=admin
# INITIAL_ADMIN_PASS=your_secure_initial_password

# بريد التنبيهات (لا تضع القيم الحقيقية هنا، فقط في .env المحلي غير المرفوع)
ADMIN_ALERT_EMAIL=admin@example.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

DB_ROOT_PASSWORD=
